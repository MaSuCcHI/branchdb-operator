FROM golang:1.26-alpine AS build
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
# k8s-dist (SPA) は //go:embed で取り込まれるためビルド時に存在する必要がある。
# web/vite build が未実行の場合は placeholder が使われる。
RUN CGO_ENABLED=0 go build -ldflags="-w -s" -o /branchdb ./cmd/branchdb

FROM gcr.io/distroless/static-debian12
COPY --from=build /branchdb /branchdb
ENTRYPOINT ["/branchdb"]
